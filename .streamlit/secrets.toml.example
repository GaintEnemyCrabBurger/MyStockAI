# ============================================================
# Streamlit Secrets 模板
# ============================================================
#
# MyStockAI 当前版本不使用任何 API Key / Token / 凭证
# （akshare 走的是公共接口），因此 **无需填写任何内容即可部署**。
#
# 本文件仅作为未来扩展模板：
# 如果将来接入了需要凭证的数据源（Tushare Pro / Finnhub /
# Alpha Vantage / OpenAI 等），按下方格式在真正的 secrets.toml
# 里填写（真正的 secrets.toml 已被 .gitignore 排除）。
#
# 使用方法（本地）：
#   1. 复制本文件为 .streamlit/secrets.toml
#   2. 按下方示例格式填入真实值
#   3. 在代码里读取：
#         import streamlit as st
#         token = st.secrets["tushare"]["token"]
#
# 使用方法（Streamlit Community Cloud）：
#   1. 打开部署好的 App
#   2. 右上角 ⋮ → Settings → Secrets
#   3. 把 TOML 内容整块粘进去，点 Save
#   4. App 会自动重启并读取
# ============================================================


# ---- Tushare Pro（A 股更细粒度数据）----
# [tushare]
# token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ---- Finnhub（美股实时 / 基本面）----
# [finnhub]
# api_key = "yyyyyyyyyyyyyyyyyyyyyyyyyyy"


# ---- Alpha Vantage（全球市场备用源）----
# [alpha_vantage]
# api_key = "zzzzzzzzzzzzzzzzzzzzzzzzz"


# ---- 其它通用配置（如果后面想用）----
# [app]
# admin_password = "change_me"
